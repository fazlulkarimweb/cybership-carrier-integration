# UPS Rating API credentials.
#
# Obtain these from https://developer.ups.com/ — create an app and
# subscribe it to the Rating API.

# Sandbox:    https://wwwcie.ups.com
# Production: https://onlinetools.ups.com
UPS_BASE_URL=https://wwwcie.ups.com

UPS_CLIENT_ID=your-client-id
UPS_CLIENT_SECRET=your-client-secret

# UPS shipper account number. Required for negotiated rates.
UPS_ACCOUNT_NUMBER=

# UPS Rating API version segment, e.g. v2409 (Sept 2024).
UPS_API_VERSION=v2409

# Per-request timeout in milliseconds.
UPS_TIMEOUT_MS=15000
